.env
.env.local
.env.production
.env.staging
.env.test
# Render / personal exports
uam-api.env
*.render.env
# Committed templates only:
#   .env.example              → docker compose local
#   .env.local.example        → app on host + localhost ports
#   .env.production.example   → Render + Aiven + Resend (placeholders)

