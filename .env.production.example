# =============================================================================
# PRODUCTION / test-prod — Render (Go + Redis) + Aiven MySQL + Resend
# Paste keys into Render Dashboard → Environment (do NOT commit real secrets)
# Source layout mirrors Render export (uam-api.env) — placeholders only here.
# =============================================================================

APP_ENV=production
APP_PORT=8080
# Frontend for CORS + password-reset links
APP_FRONTEND_URL=https://your-frontend.example.com
# Optional. Empty + APP_ENV=production → app trusts X-Forwarded-For (Render edge).
# Local: leave empty → ClientIP = 127.0.0.1 or ::1 when you hit API on same machine.
TRUSTED_PROXIES=

# --- Aiven MySQL ---
DB_HOST=xxxx.a.aivencloud.com
DB_PORT=28901
DB_NAME=defaultdb
DB_USER=avnadmin
DB_PASSWORD=CHANGE_ME_AIVEN_PASSWORD
# Aiven requires TLS; skip-verify OK for managed free/test (prefer CA when available)
DB_TLS_SKIP_VERIFY=true

# --- Render Redis (Internal URL) ---
# Prefer full URL; leave REDIS_PORT empty when using redis:// or rediss://
REDIS_HOST=redis://red-xxxxxxxx:6379
REDIS_PORT=
REDIS_PASSWORD=

# --- JWT ---
JWT_SECRET=CHANGE_ME_LONG_RANDOM_MIN_32_CHARS
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# --- Resend SMTP (domain From must be verified on resend.com) ---
SMTP_HOST=smtp.resend.com
# Dùng 587 (STARTTLS) hoặc 465 (SSL). KHÔNG dùng 2525 (không phải port Resend).
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=re_CHANGE_ME
SMTP_FROM=noreply@your-domain.com

# --- Security ---
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
MAX_FAILED_ATTEMPTS=5
LOCK_DURATION=15m
OTP_EXPIRY=5m
OTP_MAX_ATTEMPTS=3
# Stable random string; do not rotate casually (invalidates pending OTPs)
OTP_PEPPER=CHANGE_ME_OTP_PEPPER

# After wipe+migrate seed login:
#   email: admin@localhost.local
#   password: LocalDev@ChangeMe1
#   (API login = email, not username admin_local)
