# =============================================================================
# LOCAL + Docker Compose (infra: mysql, redis, mailpit)
# Copy:  cp .env.example .env
# Run:   docker compose up -d  &&  go run ./cmd/server  (or make.cmd run)
# =============================================================================

# Server
APP_ENV=development
APP_PORT=8080
APP_FRONTEND_URL=http://localhost:3000
# Behind reverse proxy only (empty = Gin trusts none)
TRUSTED_PROXIES=

# Database (service name "mysql" inside compose network)
DB_HOST=mysql
DB_PORT=3306
DB_NAME=uam_db
DB_USER=uam_user
DB_PASSWORD=uam_password
DB_ROOT_PASSWORD=root_password
# Local compose MySQL usually without TLS
DB_TLS_SKIP_VERIFY=false

# Redis (service name "redis")
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (min 16 chars — change in real use)
JWT_SECRET=dev-only-change-me-min-16-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Mail — Mailpit. Inbox UI: http://localhost:8025
# App trên host: SMTP_HOST=127.0.0.1 SMTP_PORT=1026 (map docker 1026:1025)
# App trong cùng compose network: SMTP_HOST=mailpit SMTP_PORT=1025
SMTP_HOST=127.0.0.1
SMTP_PORT=1026
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@localhost

# Security
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
MAX_FAILED_ATTEMPTS=5
LOCK_DURATION=30m
OTP_EXPIRY=5m
OTP_MAX_ATTEMPTS=5
# Empty = fall back to JWT_SECRET
OTP_PEPPER=

# Bootstrap admin (after migrate) — login with EMAIL + password only:
#   admin@localhost.local / LocalDev@ChangeMe1
#   (username in DB: admin_local — not for login)
