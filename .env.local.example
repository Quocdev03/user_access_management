# =============================================================================
# LOCAL — app on host, MySQL/Redis on localhost (Docker published ports)
# Copy:  cp .env.local.example .env
# =============================================================================

APP_ENV=development
APP_PORT=8080
APP_FRONTEND_URL=http://localhost:3001
TRUSTED_PROXIES=

DB_HOST=localhost
DB_PORT=3306
DB_NAME=uam_db
DB_USER=uam_user
DB_PASSWORD=uam_password
DB_ROOT_PASSWORD=root_password
DB_TLS_SKIP_VERIFY=false

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_SECRET=dev-only-change-me-min-16-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Mailpit: docker compose up -d mailpit → inbox http://localhost:8025
# Port host 1026 (xem docker-compose). SMTP_HOST trống = MockSender.
SMTP_HOST=127.0.0.1
SMTP_PORT=1026
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@localhost

RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
MAX_FAILED_ATTEMPTS=5
LOCK_DURATION=30m
OTP_EXPIRY=5m
OTP_MAX_ATTEMPTS=5
OTP_PEPPER=
